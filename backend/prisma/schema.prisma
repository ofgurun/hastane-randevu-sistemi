// Prisma şeması — Hastane Randevu Sistemi (MVP)
// data-model.md'ye göre: User, Department, Doctor, Appointment + enum'lar

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Enum'lar ---

enum Role {
  HASTA
  DOKTOR
  ADMIN
}

enum AppointmentStatus {
  AKTIF
  IPTAL
}

// --- Modeller ---

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String // yalnızca bcrypt hash saklanır
  role      Role     @default(HASTA)
  createdAt DateTime @default(now())

  // İlişkiler
  doctorProfile Doctor? // DOKTOR ise 1:1 profil
  appointments  Appointment[] @relation("PatientAppointments") // HASTA olarak alınan randevular
  reviews       Review[] // HASTA olarak bıraktığı değerlendirmeler
}

model Department {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  doctors Doctor[]
}

model Doctor {
  id             Int    @id @default(autoincrement())
  userId         Int    @unique
  departmentId   Int
  title          String
  backupDoctorId Int? // aynı bölümden yedek doktor (izin/silme durumunda randevular ona aktarılır)

  user         User          @relation(fields: [userId], references: [id])
  department   Department    @relation(fields: [departmentId], references: [id])
  appointments Appointment[]
  reviews      Review[]
  timeBlocks   TimeBlock[]
  backupDoctor Doctor?       @relation("DoctorBackup", fields: [backupDoctorId], references: [id])
  backupFor    Doctor[]      @relation("DoctorBackup")
}

model Appointment {
  id        Int               @id @default(autoincrement())
  patientId Int
  doctorId  Int
  date         DateTime // randevu günü
  timeSlot     String // "HH:mm" 30 dk slot (ör. "09:30")
  status       AppointmentStatus @default(AKTIF)
  reminderSent Boolean           @default(false) // hatırlatma e-postası gönderildi mi
  createdAt    DateTime          @default(now())

  patient User    @relation("PatientAppointments", fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
  review  Review?

  // NOT: (doctorId, date, timeSlot) benzersizlik kısıtı KALDIRILDI.
  // Çakışma kontrolü uygulama katmanında yalnızca status = 'AKTIF' kayıtlar
  // üzerinden yapılır; böylece IPTAL satırları slotu bloke etmez (FR-016 / SC-004).
  @@index([patientId])
  @@index([doctorId, date])
}

// --- Kapalı Zamanlar (admin takvim yönetimi) ---
// timeSlot NULL ise o gün komple kapalıdır; doluysa yalnızca o saat kapalıdır.
model TimeBlock {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  date      DateTime // gün (yerel gün başı)
  timeSlot  String? // "HH:mm" veya null (tüm gün)
  createdAt DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([doctorId, date])
}

// --- Hizmet Değerlendirmesi (yönetici talebi) ---
// Bir randevu için tek bir değerlendirme (appointmentId unique = 1:1).
model Review {
  id            Int      @id @default(autoincrement())
  appointmentId Int      @unique
  patientId     Int
  doctorId      Int
  rating        Int
  comment       String
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     User        @relation(fields: [patientId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])

  @@index([doctorId])
  @@index([patientId])
}
