# --- Veritabanı (Supabase Postgres) ---
# Uygulama bağlantısı: transaction-mode pooler (pgbouncer, IPv4, port 6543)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<YOUR-PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Migration bağlantısı: session-mode pooler (direct, port 5432)
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<YOUR-PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres"

# --- Kimlik Doğrulama ---
JWT_SECRET="degistir-bunu-guclu-bir-gizli-anahtar-ile"

# --- Sunucu ---
PORT=5000

# --- Frontend adresi (şifre sıfırlama linki bununla kurulur) ---
# Lokal geliştirmede Vite dev sunucusu; canlıda Vercel adresiniz.
FRONTEND_URL="http://localhost:5173"

# --- E-posta (test için Ethereal SMTP) ---
# https://ethereal.email üzerinden ücretsiz test hesabı alın (veya size verilen değerleri kullanın).
EMAIL_HOST="smtp.ethereal.email"
EMAIL_PORT=587
EMAIL_USER="<ethereal-kullanıcı>"
EMAIL_PASS="<ethereal-parola>"
EMAIL_FROM="Hastane Randevu <no-reply@hastane.local>"
